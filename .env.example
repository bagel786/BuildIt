# Copy this file to .env and add your Groq API key
# Get your key at https://console.groq.com/keys
# Server-side only (no VITE_ prefix) — the key never reaches the browser
GROQ_API_KEY=your_api_key_here

# Optional — community gallery backend (falls back to localStorage if unset)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
